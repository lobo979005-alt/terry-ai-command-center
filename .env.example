# ============================================================
#  必填 - Anthropic API
# ============================================================
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxx

# ============================================================
#  選填 - Server Port (Railway/Zeabur 會自動設)
# ============================================================
PORT=3000

# ============================================================
#  選填 - Tool 串接 (沒設的工具會走 mock 模式)
# ============================================================

# ===== 軍需官 → daikon-dashboard =====
# 不設 URL: 用 user memory 裡的 mock 數字
# 設 URL: 必須回傳 /api/pnl?start=&end=&account= JSON
DAIKON_DASHBOARD_URL=https://daikon-dashboard-production.up.railway.app
DAIKON_API_KEY=

# ===== 偵察兵 → big-order-scanner =====
# 必須暴露 /api/signals?min=&code= endpoint
BIG_ORDER_SCANNER_URL=

# ===== 情報官 → monitor.js =====
# 必須暴露 /api/news?code=&hours=&after_close= endpoint
MONITOR_API_URL=

# ===== 戰術官 → 蘿蔔戰情室 =====
# 必須暴露 /api/positions?account= endpoint
WAR_ROOM_URL=

# ===== 工程師 → telegram-assistant =====
TELEGRAM_ASSISTANT_URL=

# ===== 通訊官 → Telegram Bot tokens =====
# 從 BotFather 取得各 bot 的 token,從 bot getUpdates 取得 chat_id

# @LOBOMoney_bot
TG_TOKEN_LOBOMONEY=
TG_CHAT_LOBOMONEY=

# @lobo_ai_assistant_bot
TG_TOKEN_AI_ASSISTANT=
TG_CHAT_AI_ASSISTANT=

# @DangChong_Shenqi_Bot
TG_TOKEN_DANGCHONG=
TG_CHAT_DANGCHONG=
